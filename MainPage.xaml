<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AIFrontier.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:AIFrontier"
    xmlns:models="using:AIFrontier.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="Page_Loaded"
    SizeChanged="Page_SizeChanged"
    mc:Ignorable="d">

    <NavigationView
        x:Name="ShellNavigation"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        IsPaneToggleButtonVisible="True"
        OpenPaneLength="210"
        PaneDisplayMode="Left"
        PaneTitle="栏目"
        SelectionChanged="Navigation_SelectionChanged">

        <NavigationView.MenuItems>
            <NavigationViewItem Content="今日" Tag="全部" IsSelected="True">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE80F;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="大模型" Tag="大模型">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8F1;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Agent" Tag="Agent">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE99A;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="开源项目" Tag="开源项目">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE943;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="重要研究" Tag="重要研究">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8A5;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="收藏" Tag="收藏">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE735;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <NavigationView.FooterMenuItems>
            <NavigationViewItem Content="偏好说明" Tag="偏好">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE713;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.FooterMenuItems>

        <NavigationView.Content>
            <Grid x:Name="ContentRoot" Padding="24,18,24,24" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="FeedColumn" Width="*" />
                    <ColumnDefinition x:Name="DetailColumn" Width="440" />
                </Grid.ColumnDefinitions>

                <Grid x:Name="FeedPane" Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="4,0,4,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="AI 前沿" Style="{StaticResource TitleTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.EditionLabel, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind ViewModel.BatchLabel, Mode=OneWay}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Button Content="换一批" Click="NextBatchButton_Click" AutomationProperties.Name="换一批资讯" />
                            <Button Content="刷新" Click="RefreshButton_Click" AutomationProperties.Name="刷新新闻" />
                            <Border Padding="10,6" CornerRadius="6" Background="{ThemeResource AccentFillColorSecondaryBrush}">
                                <TextBlock Text="今日已更新" FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                    </Grid>

                    <AutoSuggestBox
                        Grid.Row="1"
                        Margin="4,0,4,14"
                        PlaceholderText="搜索标题、摘要或标签"
                        QueryIcon="Find"
                        Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        AutomationProperties.Name="搜索新闻" />

                    <Grid Grid.Row="2">
                        <ListView
                            x:Name="NewsList"
                            ItemsSource="{x:Bind ViewModel.Items}"
                            IsItemClickEnabled="True"
                            ItemClick="NewsList_ItemClick"
                            SelectionMode="Single"
                            SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
                            HorizontalContentAlignment="Stretch">
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <EntranceThemeTransition IsStaggeringEnabled="True" />
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,12" />
                                    <Setter Property="CornerRadius" Value="16" />
                                    <Setter Property="AutomationProperties.HelpText" Value="点击打开新闻详情" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:NewsItem">
                                    <Grid MinHeight="152" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="176" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Margin="10" Background="{x:Bind BrandBrush}" CornerRadius="12">
                                            <Grid>
                                                <Ellipse Width="92" Height="92" Fill="#20FFFFFF" />
                                                <Image Source="{x:Bind LogoSource}" Width="58" Height="58" Stretch="Uniform" AutomationProperties.Name="{x:Bind Brand}" />
                                                <TextBlock Text="{x:Bind Brand}" Margin="12" VerticalAlignment="Bottom" HorizontalAlignment="Center" Foreground="White" FontWeight="SemiBold" />
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="1" Padding="10,14,18,14" Spacing="7">
                                            <TextBlock Text="{x:Bind Category}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind Title}" FontSize="19" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="2" />
                                            <TextBlock Text="{x:Bind Summary}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" MaxLines="2" />
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind ReadingMeta}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" VerticalAlignment="Center" />
                                                <Button Grid.Column="1" Content="查看详情" Click="CardDetailButton_Click" Padding="10,4" AutomationProperties.Name="查看资讯详情" />
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8" Visibility="Collapsed">
                            <FontIcon Glyph="&#xE721;" FontSize="36" />
                            <TextBlock Text="没有符合条件的新闻" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock Text="换个栏目或关键词试试" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <Border
                    x:Name="DetailPane"
                    Grid.Column="1"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                    <Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Padding="20" Spacing="16">
                                <Button x:Name="CompactBackButton" Content="← 返回新闻流" Click="CompactBackButton_Click" Visibility="Collapsed" HorizontalAlignment="Left" />

                                <Border Height="210" Background="{Binding SelectedItem.BrandBrush}" CornerRadius="14">
                                    <Grid>
                                        <Ellipse Width="132" Height="132" Fill="#20FFFFFF" />
                                        <Image Source="{Binding SelectedItem.LogoSource}" Width="82" Height="82" Stretch="Uniform" />
                                        <StackPanel Margin="16" VerticalAlignment="Bottom" Orientation="Horizontal" Spacing="8">
                                            <Border Background="#CC000000" Padding="8,4" CornerRadius="5">
                                                <TextBlock Text="{Binding SelectedItem.Category}" Foreground="White" FontWeight="SemiBold" />
                                            </Border>
                                            <Border Background="#CC000000" Padding="8,4" CornerRadius="5">
                                                <TextBlock Text="{Binding SelectedItem.Confidence}" Foreground="White" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <TextBlock Text="{Binding SelectedItem.Title}" FontSize="27" FontWeight="SemiBold" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedItem.ReadingMeta}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding SelectedItem.Summary}" FontSize="17" TextWrapping="Wrap" LineHeight="27" />

                                <InfoBar
                                    IsOpen="True"
                                    IsClosable="False"
                                    Severity="Informational"
                                    Title="为什么值得看"
                                    Message="{Binding SelectedItem.WhyItMatters}" />

                                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                <StackPanel Spacing="3">
                                    <TextBlock Text="完整报道" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="按资讯类型压缩原文重点，并保持事实展开顺序" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding SelectedItem.BriefSections}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:BriefSection">
                                            <StackPanel Margin="0,0,0,18" Spacing="7">
                                                <TextBlock Text="{x:Bind Title}" FontSize="19" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                <TextBlock Text="{x:Bind Body}" FontSize="16" TextWrapping="Wrap" LineHeight="28" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                <TextBlock Text="核查要点" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <ItemsControl ItemsSource="{Binding SelectedItem.KeyFacts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,12" ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Glyph="&#xE73E;" FontSize="10" Foreground="{ThemeResource AccentFillColorDefaultBrush}" Margin="2,6,0,0" />
                                                <TextBlock Grid.Column="1" Text="{Binding}" TextWrapping="Wrap" LineHeight="25" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <InfoBar IsOpen="True" IsClosable="False" Severity="Warning" Title="报道边界" Message="{Binding SelectedItem.Limitations}" />

                                <TextBlock Text="来源链" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <ItemsControl ItemsSource="{Binding SelectedItem.SourceTrail}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,6" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="使用 Codex 深度分析" Click="AnalyzeWithCodexButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" AutomationProperties.HelpText="把当前资讯交给本机 Codex 辅助阅读" />
                                    <Button Grid.Column="1" Content="打开原始网站 ↗" Click="OpenSourceButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" AutomationProperties.HelpText="使用系统默认外部浏览器打开原始来源" />
                                </Grid>

                                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                <StackPanel Spacing="8">
                                    <TextBlock Text="读完后，这条内容对你有用吗？" Style="{StaticResource SubtitleTextBlockStyle}" />
                                    <RatingControl x:Name="PreferenceRating" MaxRating="5" ValueChanged="PreferenceRating_ValueChanged" AutomationProperties.Name="新闻喜好程度" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="喜欢" Tag="like" Click="FeedbackButton_Click" AutomationProperties.Name="喜欢这条新闻" />
                                        <Button Content="不感兴趣" Tag="dislike" Click="FeedbackButton_Click" AutomationProperties.Name="不感兴趣" />
                                        <Button Content="收藏" Tag="bookmark" Click="FeedbackButton_Click" AutomationProperties.Name="收藏新闻" />
                                    </StackPanel>
                                    <Button Content="减少此类内容" Tag="less-topic" Click="FeedbackButton_Click" HorizontalAlignment="Left" />
                                </StackPanel>

                                <InfoBar
                                    IsOpen="{x:Bind ViewModel.IsFeedbackMessageOpen, Mode=TwoWay}"
                                    IsClosable="True"
                                    Severity="Success"
                                    Message="{x:Bind ViewModel.FeedbackMessage, Mode=OneWay}" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border
                    x:Name="PreferencePane"
                    Grid.ColumnSpan="2"
                    Visibility="Collapsed"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    CornerRadius="18"
                    Padding="32">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel MaxWidth="760" HorizontalAlignment="Center" Spacing="18" Padding="0,0,12,20">
                        <FontIcon Glyph="&#xE713;" FontSize="40" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock Text="推荐偏好如何工作" Style="{StaticResource TitleTextBlockStyle}" TextAlignment="Center" />
                        <TextBlock Text="{x:Bind ViewModel.PreferenceSummary, Mode=OneWay}" FontSize="18" TextAlignment="Center" TextWrapping="Wrap" />
                        <InfoBar IsOpen="True" IsClosable="False" Severity="Informational" Title="不会形成信息茧房" Message="偏好只影响普通内容的排序和解释深度。重大模型发布、安全事件和高影响研究仍会保留，事实核查门槛不会因为点击而降低。" />
                        <TextBlock Text="工作流偏好文件" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBox Text="{x:Bind ViewModel.WorkflowProfilePath, Mode=OneWay}" IsReadOnly="True" />

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <TextBlock Text="本机 Codex 辅助阅读" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <InfoBar IsOpen="True" IsClosable="False" Severity="Informational" Title="Codex 是可选增强" Message="接入后，应用只在你主动点击时把当前资讯写入本机专用工作区，并打开 Codex 辅助分析。采集、中文简报和更新均不依赖 Codex。" />
                        <TextBlock Text="{x:Bind ViewModel.CodexStatus, Mode=OneWay}" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="接入本机 Codex" Click="ConnectCodexButton_Click" />
                        </StackPanel>
                        <TextBox Text="{x:Bind ViewModel.CodexWorkspacePath, Mode=OneWay}" IsReadOnly="True" Header="Codex 专用工作区" />

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <TextBlock Text="版本更新" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="立即检查更新" Click="CheckUpdatesButton_Click" />
                            <Button Content="恢复更新提醒" Click="ResetUpdatePromptsButton_Click" />
                        </StackPanel>
                        <TextBlock Text="固定发布位置：https://github.com/why30263-bot/ai-frontier/releases/latest。无论是否接入 Codex，应用都会定时检查。发现新版时可选择立即安装、自动更新、跳过当前版本或不再弹窗。" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="评分映射：5 星明显提高同类权重，4 星轻微提高，3 星保持，1–2 星降低。所有权重限制在 0.2–2.0。" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </NavigationView.Content>
    </NavigationView>
</Page>
