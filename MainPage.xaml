<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AIFrontier.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:AIFrontier"
    xmlns:models="using:AIFrontier.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded"
    SizeChanged="Page_SizeChanged"
    mc:Ignorable="d">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="Escape" Invoked="BackKeyboardAccelerator_Invoked" />
        <KeyboardAccelerator Key="Left" Modifiers="Menu" Invoked="BackKeyboardAccelerator_Invoked" />
    </Page.KeyboardAccelerators>

    <NavigationView
        x:Name="ShellNavigation"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        IsPaneToggleButtonVisible="True"
        OpenPaneLength="210"
        PaneDisplayMode="Left"
        PaneTitle="栏目"
        SelectionChanged="Navigation_SelectionChanged">

        <NavigationView.MenuItems>
            <NavigationViewItem Content="今日" Tag="全部" IsSelected="True" Tapped="TodayNavigation_Tapped">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE80F;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="为你推荐" Tag="为你推荐">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8D4;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="大模型" Tag="大模型">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8F1;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Agent" Tag="Agent">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE99A;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="开源项目" Tag="开源项目">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE943;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="重要研究" Tag="重要研究">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8A5;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="收藏" Tag="收藏">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE735;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <NavigationView.FooterMenuItems>
            <NavigationViewItem Content="设置" Tag="偏好">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE713;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.FooterMenuItems>

        <NavigationView.Content>
            <Grid x:Name="ContentRoot" Padding="24,18,24,24" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="FeedColumn" Width="*" />
                    <ColumnDefinition x:Name="DetailColumn" Width="440" />
                    <ColumnDefinition x:Name="ChatColumn" Width="0" />
                </Grid.ColumnDefinitions>

                <Grid x:Name="FeedPane" Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="FeedHeader" Margin="4,0,4,12" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="0" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="AI 前沿" Style="{StaticResource TitleTextBlockStyle}" />
                            <TextBlock x:Name="EditionText" Text="{x:Bind ViewModel.EditionLabel, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon Glyph="&#xE895;" FontSize="12" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.LocalNewsUpdateStatus, Mode=OneWay}"
                                    FontSize="12"
                                    TextWrapping="Wrap"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    AutomationProperties.LiveSetting="Polite" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel x:Name="HeaderCommands" Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock x:Name="BatchText" Text="{x:Bind ViewModel.BatchLabel, Mode=OneWay}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Button Content="换一批" Click="NextBatchButton_Click" AutomationProperties.Name="换一批资讯" />
                            <Button x:Name="RefreshButton" Click="RefreshButton_Click" AutomationProperties.Name="刷新新闻">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <ProgressRing x:Name="RefreshProgressRing" Width="16" Height="16" IsActive="False" Visibility="Collapsed" />
                                    <TextBlock Text="刷新最新资讯" />
                                </StackPanel>
                            </Button>
                            <Button
                                Content="停止"
                                IsEnabled="{x:Bind ViewModel.IsLocalNewsUpdateBusy, Mode=OneWay}"
                                Click="StopDailyNewsUpdateButton_Click"
                                AutomationProperties.Name="停止本机资讯更新" />
                        </StackPanel>
                    </Grid>

                    <AutoSuggestBox
                        Grid.Row="1"
                        Margin="4,0,4,14"
                        PlaceholderText="搜索标题、摘要或标签"
                        QueryIcon="Find"
                        Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        AutomationProperties.Name="搜索新闻" />

                    <Grid Grid.Row="2">
                        <ListView
                            x:Name="NewsList"
                            ItemsSource="{x:Bind ViewModel.Items}"
                            IsItemClickEnabled="True"
                            ItemClick="NewsList_ItemClick"
                            SelectionMode="Single"
                            SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
                            HorizontalContentAlignment="Stretch">
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <EntranceThemeTransition IsStaggeringEnabled="True" />
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,12" />
                                    <Setter Property="CornerRadius" Value="16" />
                                    <Setter Property="AutomationProperties.HelpText" Value="点击打开新闻详情" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:NewsItem">
                                    <Grid MinHeight="120" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" AutomationProperties.Name="{x:Bind AccessibleTitle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="112" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Margin="8" Background="{x:Bind BrandBrush}" CornerRadius="10">
                                            <Grid>
                                                <Ellipse Width="64" Height="64" Fill="#20FFFFFF" />
                                                <Image Source="{x:Bind LogoSource}" Width="42" Height="42" Stretch="Uniform" IsHitTestVisible="False" />
                                                <TextBlock Text="{x:Bind Brand}" Margin="8" VerticalAlignment="Bottom" HorizontalAlignment="Center" Foreground="White" FontSize="12" FontWeight="SemiBold" MaxLines="1" />
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="1" Padding="8,10,14,10" Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{x:Bind ContentLabel}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <Border
                                                    Visibility="{x:Bind NewBadgeVisibility}"
                                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                    CornerRadius="5"
                                                    Padding="7,2">
                                                    <TextBlock Text="NEW" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" FontSize="10" FontWeight="Bold" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Title}" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="2" />
                                            <TextBlock Text="{x:Bind Summary}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" MaxLines="2" FontSize="13" />
                                            <TextBlock Text="{x:Bind ReadingMeta}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="11" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8" Visibility="Collapsed">
                            <FontIcon Glyph="&#xE721;" FontSize="36" />
                            <TextBlock Text="没有符合条件的新闻" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock Text="换个栏目或关键词试试" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <Border
                    x:Name="DetailPane"
                    Grid.Column="1"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                    <Grid>
                        <ScrollViewer x:Name="DetailScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Center">
                            <StackPanel MaxWidth="800" HorizontalAlignment="Center" Padding="24" Spacing="16">
                                <Button x:Name="CompactBackButton" Content="← 返回新闻流" Click="CompactBackButton_Click" Visibility="Collapsed" HorizontalAlignment="Left" />

                                <TextBlock Text="{Binding SelectedItem.ContentLabel}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="SemiBold" />
                                 <TextBlock Text="{Binding SelectedItem.Title}" FontSize="27" FontWeight="SemiBold" TextWrapping="Wrap" AutomationProperties.HeadingLevel="Level1" />
                                 <TextBlock Text="{Binding SelectedItem.ReadingMeta}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                 <Border
                                     Padding="18,16"
                                     Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                     BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                     BorderThickness="4,0,0,0"
                                     CornerRadius="12">
                                     <StackPanel Spacing="7">
                                         <TextBlock Text="先看结论" FontSize="17" FontWeight="SemiBold" AutomationProperties.HeadingLevel="Level2" />
                                         <TextBlock Text="{Binding SelectedItem.Summary}" FontSize="16" TextWrapping="Wrap" LineHeight="27" IsTextSelectionEnabled="True" />
                                     </StackPanel>
                                 </Border>

                                <Border
                                    Padding="16"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <StackPanel Spacing="7">
                                         <TextBlock Text="这是什么领域" FontSize="17" FontWeight="SemiBold" AutomationProperties.HeadingLevel="Level2" />
                                        <TextBlock Text="{Binding SelectedItem.ReaderContext}" FontSize="15" TextWrapping="Wrap" LineHeight="25" />
                                    </StackPanel>
                                </Border>

                                 <TextBlock Text="读前术语" FontSize="17" FontWeight="SemiBold" AutomationProperties.HeadingLevel="Level2" />
                                 <ItemsControl ItemsSource="{Binding SelectedItem.TermExplanations}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:TermExplanation">
                                            <Border
                                                Margin="0,0,0,8"
                                                Padding="14,12"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                CornerRadius="10">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{x:Bind Term}" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                                    <TextBlock Text="{x:Bind Explanation}" TextWrapping="Wrap" LineHeight="23" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                <ItemsControl ItemsSource="{Binding SelectedItem.BriefSections}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:BriefSection">
                                            <StackPanel Margin="0,0,0,18" Spacing="7">
                                                <TextBlock Text="{x:Bind Title}" FontSize="19" FontWeight="SemiBold" TextWrapping="Wrap" AutomationProperties.HeadingLevel="Level2" />
                                                <TextBlock Text="{x:Bind Body}" FontSize="16" TextWrapping="Wrap" LineHeight="28" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Grid x:Name="ReadingActions" ColumnSpacing="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="0" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="AnalyzeWithCodexButton" Click="AnalyzeWithCodexButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" AutomationProperties.Name="使用 Codex 深度分析当前资讯" AutomationProperties.HelpText="在应用内打开 Codex 工作区并分析当前资讯">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <ProgressRing x:Name="CodexProgressRing" Width="16" Height="16" IsActive="False" Visibility="Collapsed" />
                                            <TextBlock Text="使用 Codex 深度分析" />
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="OpenSourceButton" Grid.Column="1" Content="打开原始网站 ↗" Click="OpenSourceButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" AutomationProperties.HelpText="使用系统默认外部浏览器打开原始来源" />
                                </Grid>

                                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                <StackPanel Spacing="8">
                                    <TextBlock Text="读完后，这条内容对你有用吗？" Style="{StaticResource SubtitleTextBlockStyle}" />
                                    <RatingControl x:Name="PreferenceRating" MaxRating="5" ValueChanged="PreferenceRating_ValueChanged" AutomationProperties.Name="新闻喜好程度" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ToggleButton Content="喜欢" Tag="like" Click="FeedbackButton_Click" IsChecked="{x:Bind ViewModel.IsSelectedLiked, Mode=OneWay}" AutomationProperties.Name="喜欢这条新闻" />
                                        <ToggleButton Content="不感兴趣" Tag="dislike" Click="FeedbackButton_Click" IsChecked="{x:Bind ViewModel.IsSelectedDisliked, Mode=OneWay}" AutomationProperties.Name="不感兴趣" />
                                        <ToggleButton Content="收藏" Tag="bookmark" Click="FeedbackButton_Click" IsChecked="{x:Bind ViewModel.IsSelectedBookmarked, Mode=OneWay}" AutomationProperties.Name="收藏新闻" />
                                    </StackPanel>
                                    <ToggleButton Content="减少此类内容" Tag="less-topic" Click="FeedbackButton_Click" HorizontalAlignment="Left" IsChecked="{x:Bind ViewModel.IsSelectedLessTopic, Mode=OneWay}" AutomationProperties.Name="减少或恢复此类内容" />
                                </StackPanel>

                                <InfoBar
                                    IsOpen="{x:Bind ViewModel.IsFeedbackMessageOpen, Mode=TwoWay}"
                                    IsClosable="True"
                                    Severity="Success"
                                    AutomationProperties.LiveSetting="Polite"
                                    Message="{x:Bind ViewModel.FeedbackMessage, Mode=OneWay}" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border
                    x:Name="CodexChatPane"
                    Grid.Column="2"
                    Visibility="Collapsed"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Canvas.ZIndex="20"
                    AutomationProperties.Name="Codex 辅助阅读工作区">
                    <Grid Padding="18" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="10">
                                <FontIcon Glyph="&#xE99A;" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" FontSize="18" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                <TextBlock Text="Codex 阅读工作区" FontSize="18" FontWeight="SemiBold" AutomationProperties.HeadingLevel="Level2" />
                                <TextBlock Text="围绕当前资讯持续追问" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <Button x:Name="NewCodexConversationButton" Grid.Column="2" Content="新对话" Click="NewCodexConversationButton_Click" AutomationProperties.Name="开始新的 Codex 对话" />
                            <Button Grid.Column="3" Content="&#xE711;" FontFamily="Segoe Fluent Icons" Click="CloseCodexChatButton_Click" AutomationProperties.Name="关闭 Codex 工作区" />
                        </Grid>

                        <Border Grid.Row="1" Padding="12,9" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="10">
                            <StackPanel Spacing="3">
                                <TextBlock Text="当前资讯" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                 <TextBlock Text="{Binding SelectedItem.Title}" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="2" />
                            </StackPanel>
                        </Border>

                        <ListView
                            x:Name="CodexMessageList"
                            Grid.Row="2"
                            ItemsSource="{x:Bind CodexMessages}"
                            SelectionMode="None"
                            HorizontalContentAlignment="Stretch"
                            AutomationProperties.Name="Codex 对话消息">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,10" />
                                    <Setter Property="IsTabStop" Value="False" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:CodexChatMessage">
                                     <Border Padding="13,11" Background="{x:Bind BubbleBackground}" BorderBrush="{x:Bind BubbleBorderBrush}" BorderThickness="1" CornerRadius="12" HorizontalAlignment="{x:Bind BubbleAlignment}" MaxWidth="{x:Bind BubbleMaxWidth}">
                                        <StackPanel Spacing="5">
                                            <Grid>
                                                <TextBlock Text="{x:Bind SenderLabel}" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                                <TextBlock Text="{x:Bind TimeLabel}" HorizontalAlignment="Right" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            </Grid>
                                             <TextBlock Text="{x:Bind Content, Mode=OneWay}" TextWrapping="Wrap" LineHeight="24" IsTextSelectionEnabled="True" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <StackPanel Grid.Row="3" Spacing="8">
                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Tag="请用一句话解释这条资讯最重要的结论。" Click="CodexQuickPromptButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" AutomationProperties.Name="快捷追问：用一句话解释">
                                    <TextBlock Text="用一句话解释" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                </Button>
                                <Button Grid.Column="1" Tag="这项进展有哪些关键局限和容易误解的地方？" Click="CodexQuickPromptButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" AutomationProperties.Name="快捷追问：有什么局限">
                                    <TextBlock Text="有什么局限" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                </Button>
                                <Button Grid.Column="2" Tag="请面向没有专业基础的读者解释这条资讯。" Click="CodexQuickPromptButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" AutomationProperties.Name="快捷追问：给新手讲讲">
                                    <TextBlock Text="给新手讲讲" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                </Button>
                            </Grid>
                            <StackPanel x:Name="CodexBusyPanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed" AutomationProperties.LiveSetting="Polite">
                                <ProgressRing x:Name="CodexChatProgressRing" Width="16" Height="16" IsActive="False" />
                                <TextBlock Text="Codex 正在阅读和整理…" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Button Content="停止" Click="StopCodexButton_Click" Padding="10,3" AutomationProperties.Name="停止 Codex 回答" />
                            </StackPanel>
                        </StackPanel>

                        <Grid Grid.Row="4" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="CodexPromptTextBox"
                                PlaceholderText="继续追问当前资讯…"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                MaxHeight="120"
                                KeyDown="CodexPromptTextBox_KeyDown"
                                AutomationProperties.Name="输入 Codex 问题" />
                            <Button
                                x:Name="SendCodexMessageButton"
                                Grid.Column="1"
                                Content="发送"
                                Click="SendCodexMessageButton_Click"
                                VerticalAlignment="Stretch"
                                AutomationProperties.Name="发送消息给 Codex" />
                        </Grid>
                    </Grid>
                </Border>

                <Border
                    x:Name="PreferencePane"
                    Grid.ColumnSpan="3"
                    Visibility="Collapsed"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    CornerRadius="18"
                    Padding="32">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel MaxWidth="760" HorizontalAlignment="Center" Spacing="18" Padding="0,0,12,20">
                        <FontIcon Glyph="&#xE713;" FontSize="40" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock Text="设置" Style="{StaticResource TitleTextBlockStyle}" TextAlignment="Center" />

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <TextBlock Text="本机 Codex 辅助阅读" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.CodexStatus, Mode=OneWay}" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="ConnectCodexButton" Click="ConnectCodexButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <ProgressRing x:Name="ConnectCodexProgressRing" Width="16" Height="16" IsActive="False" Visibility="Collapsed" />
                                    <TextBlock Text="接入本机 Codex" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Border
                            Padding="16"
                            CornerRadius="12"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                            <StackPanel Spacing="12">
                                <TextBlock Text="每日资讯更新" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.LocalNewsUpdateStatus, Mode=OneWay}"
                                    TextWrapping="Wrap"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    AutomationProperties.LiveSetting="Polite" />
                                <ToggleSwitch
                                    Header="个人模式"
                                    OffContent="云端优先"
                                    OnContent="只用本机 Codex"
                                    IsOn="{x:Bind ViewModel.IsPersonalUpdateMode, Mode=OneWay}"
                                    Toggled="PersonalUpdateMode_Toggled" />
                                <TextBlock
                                    Text="开启后，每天启动软件都会由本机 Codex 静默采集并整理资讯，不再依赖云端简报。"
                                    TextWrapping="Wrap"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <ToggleSwitch
                                    Header="云端异常时自动接管"
                                    OffContent="关闭"
                                    OnContent="已开启"
                                    IsOn="{x:Bind ViewModel.IsLocalFallbackEnabled, Mode=OneWay}"
                                    Toggled="LocalFallback_Toggled" />
                                <Button
                                    x:Name="UpdateTodayWithCodexButton"
                                    Click="UpdateTodayWithCodexButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ProgressRing
                                            Width="16"
                                            Height="16"
                                            IsActive="{x:Bind ViewModel.IsLocalNewsUpdateBusy, Mode=OneWay}" />
                                        <TextBlock Text="立即检查并更新今日资讯" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <TextBlock Text="版本更新" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <HyperlinkButton
                            x:Name="ManualUpdateLink"
                            Content="自动更新失败？在浏览器中下载最新版"
                            NavigateUri="https://github.com/why30263-bot/ai-frontier/releases/latest"
                            Visibility="Collapsed" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="CheckUpdatesButton" Click="CheckUpdatesButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <ProgressRing x:Name="UpdateProgressRing" Width="16" Height="16" IsActive="False" Visibility="Collapsed" />
                                    <TextBlock Text="立即检查更新" />
                                </StackPanel>
                            </Button>
                            <Button Content="恢复更新提醒" Click="ResetUpdatePromptsButton_Click" />
                        </StackPanel>
                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </NavigationView.Content>
    </NavigationView>
</Page>
